DATABASE_URL=mysql+pymysql://root:你的密码@127.0.0.1:3306/exam_bank?charset=utf8mb4

# AI_PROVIDER 可选：zhipu / openai
AI_PROVIDER=zhipu

# 智谱 GLM / CogView
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_VISION_MODEL=glm-4v-plus
ZHIPU_TEXT_MODEL=glm-4-plus
ZHIPU_IMAGE_MODEL=cogview-3-flash
ZHIPU_IMAGE_SIZE=1024x1024

# 生成题目时，默认优先使用 SVG / 后端立方体模板。
# 如果希望模型返回 image_prompt 后调用智谱生图接口，改为 true。
ENABLE_IMAGE_GENERATION=false

# 如果智谱账号/模型不支持 response_format，可改为 none。
AI_RESPONSE_FORMAT=json_object

# OpenAI 兼容配置，保留用于切换回 OpenAI 或其它兼容服务。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.5
